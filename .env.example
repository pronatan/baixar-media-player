# Caminho do binário yt-dlp (deixe vazio para usar o padrão)
YTDLP_PATH=

# Proxy residencial para contornar bloqueio de IP de datacenter
# Formato: http://usuario:senha@host:porta
# Serviços recomendados: Webshare.io (plano gratuito disponível), Bright Data, Oxylabs
YTDLP_PROXY=

# Lista de proxies para rotação (JSON array) — usado se YTDLP_PROXY estiver vazio
# Exemplo: ["http://user:pass@host1:porta","http://user:pass@host2:porta"]
YTDLP_PROXY_LIST=
